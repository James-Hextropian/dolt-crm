# Railway environment variables — copy these into your Railway service settings
# Do NOT commit .env with real values

# Hosted DoltDB connection
DOLT_HOST=your-instance.dbs.hosted.doltdb.com
DOLT_PORT=3306
DOLT_USER=your_dolt_user
DOLT_PASSWORD=your_dolt_password
DOLT_DATABASE=dolt_crm
DB_USE_SSL=true

# App
NODE_ENV=production
PORT=3003

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=replace_with_64_byte_random_base64_string
JWT_REFRESH_SECRET=replace_with_another_64_byte_random_base64_string

# Set to your Railway public URL (e.g. https://dolt-crm.up.railway.app)
# Leave blank if backend serves the frontend as static files (recommended)
FRONTEND_URL=
